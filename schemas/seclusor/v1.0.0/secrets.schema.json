{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "seclusor/v1.0.0/secrets",
  "title": "seclusor Secrets File Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "projects"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "v1.0.0"
      ]
    },
    "env_prefix": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "projects": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_slug",
        "credentials"
      ],
      "properties": {
        "project_slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "description": {
          "type": "string"
        },
        "credentials": {
          "type": "object",
          "maxProperties": 500,
          "propertyNames": {
            "pattern": "^[A-Z_][A-Z0-9_]*$",
            "maxLength": 128
          },
          "additionalProperties": {
            "$ref": "#/$defs/credential"
          }
        }
      }
    },
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1048576,
          "pattern": "\\S"
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "pattern": "\\S"
        },
        "description": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "required": [
            "value"
          ],
          "not": {
            "required": [
              "ref"
            ]
          }
        },
        {
          "required": [
            "ref"
          ],
          "not": {
            "required": [
              "value"
            ]
          }
        }
      ]
    }
  }
}
